def len_last_lastword(s):
    count = 0
    n = len(s)
    
    for i in range(n-1, -1, -1):  # iterate from end to start
        if s[i] != " ":            # check if current character is not a space
            count += 1
        else:
            if count > 0:          # if we already counted some letters, return
                return count
    return count                   # return count if loop finishes

s = "Hello world"
print(len_last_lastword(s))       # Output: 5
